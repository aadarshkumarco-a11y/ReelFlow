generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  name           String
  passwordHash   String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  instagramAccounts InstagramAccount[]
  driveFolders       DriveFolder[]
  uploads            Upload[]
  logs               Log[]
  settings           Settings[]
}

model InstagramAccount {
  id            String    @id @default(cuid())
  userId        String
  igUserId      String
  username      String
  pageId        String
  accessToken   String
  tokenExpiresAt DateTime
  accountType   String    @default("business")
  profilePicUrl String?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads       Upload[]
}

model DriveFolder {
  id         String   @id @default(cuid())
  userId     String
  folderId   String
  folderUrl  String
  label      String
  videoCount Int      @default(0)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads    Upload[]
}

model Upload {
  id              String    @id @default(cuid())
  userId          String
  igAccountId     String
  driveFolderId   String?
  videoFileId     String?
  videoFileName   String
  videoUrl        String?
  videoFileSize   Int?
  caption         String
  status          String    @default("pending")
  errorMessage    String?
  instagramMediaId String?
  containerId     String?
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  igAccount       InstagramAccount @relation(fields: [igAccountId], references: [id])
  driveFolder     DriveFolder?     @relation(fields: [driveFolderId], references: [id])
}

model Log {
  id        String   @id @default(cuid())
  userId    String
  level     String   @default("info")
  message   String
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id               String   @id @default(cuid())
  userId           String   @unique
  defaultCaption   String   @default("")
  maxRetries       Int      @default(3)
  autoRetryEnabled Boolean  @default(true)
  theme            String   @default("dark")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
